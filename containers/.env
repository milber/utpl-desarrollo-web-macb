# --- MariaDB Credentials ---
# IMPORTANT: Change these values to strong, secure, and unique passwords.

# Root user password for the MariaDB service
DB_ROOT_PASS=my-secret-root-password

# Name of the default database to be created
DB_NAME=my_database

# Credentials for a regular application user
DB_USER=my_user
DB_PASS=mmy_user_password



# YSQL_ROOT_PASSWORD: my-secret-root-password
#       MYSQL_DATABASE: my_database
#       MYSQL_USER: my_user
#       MYSQL_PASSWORD: my_user_password